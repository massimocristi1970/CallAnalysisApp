#!/bin/sh

remote_name="$1"
remote_url="$2"
current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"

if [ "$remote_name" != "origin" ]; then
  exit 0
fi

if [ "$current_branch" != "main" ]; then
  exit 0
fi

if [ -z "$HF_TOKEN" ] && [ ! -f ".env" ]; then
  echo "[post-push] Skipping Hugging Face database sync: HF_TOKEN is not configured."
  exit 0
fi

if command -v python >/dev/null 2>&1; then
  python upload_to_hf.py --quiet || echo "[post-push] Hugging Face database sync failed."
else
  echo "[post-push] Python is not available; skipping Hugging Face database sync."
fi
